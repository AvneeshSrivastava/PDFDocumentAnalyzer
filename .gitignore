# ==========================================================
# Python
# ==========================================================

# Compiled Python files
__pycache__/
*.py[cod]
*$py.class

# ==========================================================
# Virtual Environment
# ==========================================================

venv/
.env
.env.*

# ==========================================================
# IDE Configuration
# ==========================================================

.vscode/
.idea/

# ==========================================================
# Testing
# ==========================================================

.pytest_cache/
.coverage
htmlcov/

# ==========================================================
# Application Logs
# ==========================================================

# Ignore generated log files
logs/*.log

# Keep the logs directory in Git
!logs/.gitkeep

# ==========================================================
# Uploaded Files
# ==========================================================

# Ignore uploaded PDFs
data/input/*

# Ignore generated output files
data/output/*

# Keep empty folders in Git
!data/input/.gitkeep
!data/output/.gitkeep

# ==========================================================
# Operating System Files
# ==========================================================

Thumbs.db
.DS_Store

# ==========================================================
# Certificates & Secrets
# ==========================================================

*.pem
*.key
*.crt
*.pfx

github-recovery-codes.txt

# ==========================================================
# Executables
# ==========================================================

*.exe
*.msi